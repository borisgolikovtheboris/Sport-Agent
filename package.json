{
  "name": "sportbot",
  "version": "1.0.0",
  "description": "Telegram bot for organizing group sports events",
  "main": "dist/bot/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/bot/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/bot/index.js",
    "db:push": "prisma db push --accept-data-loss"
  },
  "dependencies": {
    "grammy": "^1.21.1",
    "@grammyjs/conversations": "^1.2.0",
    "@prisma/client": "^5.10.0",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.11.5"
  }
}
