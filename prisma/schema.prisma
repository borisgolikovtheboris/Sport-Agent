generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  chatId  String   @id
  title   String
  adminId String
  addedAt DateTime @default(now())
  events  Event[]
}

model Event {
  id              String        @id @default(uuid())
  groupId         String
  messageId       Int?
  title           String
  datetime        DateTime
  maxParticipants Int?
  createdBy       String
  status          EventStatus   @default(ACTIVE)
  createdAt       DateTime      @default(now())
  group           Group         @relation(fields: [groupId], references: [chatId])
  participants    Participant[]
}

model Participant {
  id        String            @id @default(uuid())
  eventId   String
  userId    String
  username  String?
  firstName String
  status    ParticipantStatus @default(GOING)
  joinedAt  DateTime          @default(now())
  event     Event             @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
}

enum EventStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum ParticipantStatus {
  GOING
  NOT_GOING
}
