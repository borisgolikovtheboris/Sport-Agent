{
  "name": "sportbot",
  "version": "1.1.0",
  "description": "Telegram bot for organizing group workouts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc && cp -r src/dashboard dist/dashboard",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.0.3",
    "@prisma/client": "^6.5.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "grammy": "^1.35.0",
    "prisma": "^6.5.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
