generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Group {
  chatId  String        @id
  title   String
  adminId String
  addedAt DateTime      @default(now())
  events  Event[]
  series  EventSeries[]
}

model EventSeries {
  id              String    @id @default(uuid())
  groupId         String
  createdBy       String
  title           String
  time            String    // HH:MM
  daysOfWeek      Int[]     // 0=вс, 1=пн, 2=вт, 3=ср, 4=чт, 5=пт, 6=сб
  maxParticipants Int?
  price           Int?
  paymentInfo     String?
  startsFrom      DateTime
  endsAt          DateTime
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  events          Event[]
  group           Group     @relation(fields: [groupId], references: [chatId])
}

model Event {
  id                  String        @id @default(uuid())
  groupId             String
  messageId           Int?
  title               String
  datetime            DateTime
  maxParticipants     Int?
  price               Int?
  paymentInfo         String?
  lastPaymentReminder DateTime?
  createdBy           String
  status              EventStatus   @default(ACTIVE)
  createdAt           DateTime      @default(now())
  seriesId            String?
  group               Group         @relation(fields: [groupId], references: [chatId])
  series              EventSeries?  @relation(fields: [seriesId], references: [id])
  participants        Participant[]
  payments            Payment[]
  reminders           Reminder[]
}

model Participant {
  id        String            @id @default(uuid())
  eventId   String
  userId    String
  username  String?
  firstName String
  status    ParticipantStatus @default(GOING)
  joinedAt  DateTime          @default(now())
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Reminder {
  id                String         @id @default(uuid())
  eventId           String
  type              ReminderType
  scheduledFor      DateTime
  sentAt            DateTime?
  status            ReminderStatus @default(PENDING)
  reminderMessageId Int?
  event             Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String        @id @default(uuid())
  eventId     String
  userId      String
  username    String?
  firstName   String
  status      PaymentStatus @default(PENDING)
  confirmedAt DateTime?
  verifiedAt  DateTime?
  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

enum EventStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum ParticipantStatus {
  GOING
  NOT_GOING
}

enum ReminderType {
  SIGNUP_24H
  PAYMENT_AFTER
  SERIES_PUBLISH_48H
}

enum ReminderStatus {
  PENDING
  SENT
  SKIPPED
}

model NLULog {
  id           String   @id @default(uuid())
  groupId      String
  userId       String
  inputText    String
  intent       String
  confidence   Float
  entities     Json?
  latencyMs    Int
  success      Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([groupId])
}

enum PaymentStatus {
  PENDING
  SELF_CONFIRMED
  VERIFIED
  REJECTED
}
